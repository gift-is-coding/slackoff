# Slackoff — Environment Variables
# Copy this file to .env.local and fill in any values you need to override.
# All variables are optional — defaults work with a standard OpenClaw installation.
#
# Usage:
#   cp .env.example .env.local
#   # Edit .env.local as needed, then:
#   npm run dev

# ──────────────────────────────────────────────
# OpenClaw Config File
# ──────────────────────────────────────────────

# Path to your openclaw.json config file.
# Default: ~/.openclaw/openclaw.json
# OPENCLAW_CONFIG_PATH=

# ──────────────────────────────────────────────
# Gateway Connection
# ──────────────────────────────────────────────

# WebSocket URL for the local OpenClaw gateway.
# Default: ws://127.0.0.1:18789  (reads port from openclaw.json)
# OPENCLAW_GATEWAY_URL=

# Gateway auth token — server-side only, never exposed to the browser.
# If not set, falls back to the token in openclaw.json.
# OPENCLAW_GATEWAY_TOKEN=

# Alternative: password-based gateway auth.
# If not set, falls back to the password in openclaw.json.
# OPENCLAW_GATEWAY_PASSWORD=

# ──────────────────────────────────────────────
# Agent & Session
# ──────────────────────────────────────────────

# RPC session key used for gateway calls.
# Default: agent:main:slackoff
# OPENCLAW_SLACKOFF_SESSION_KEY=

# Root directory for OpenClaw workspace files.
# Default: ~/.openclaw
# OPENCLAW_STATE_DIR=

# Agent ID used for CLI calls (openclaw agent --agent-id <id>).
# Default: main
# OPENCLAW_AGENT_ID=

# Agent ID override for the web channel / debug console.
# Default: same as OPENCLAW_AGENT_ID
# OPENCLAW_CHANNEL_AGENT_ID=

# ──────────────────────────────────────────────
# File Paths
# ──────────────────────────────────────────────

# Absolute path to notification-inbox.json.
# Default: <OPENCLAW_STATE_DIR>/workspace/memory/notification-inbox.json
# OPENCLAW_NOTIFICATION_INBOX_PATH=

# Path or name of the openclaw CLI binary.
# Default: openclaw  (must be on your PATH)
# OPENCLAW_BIN=

# ──────────────────────────────────────────────
# Session IDs
# ──────────────────────────────────────────────

# Session ID for the debug console (web channel).
# Default: slackoff_web_channel
# OPENCLAW_SLACKOFF_CHANNEL_SESSION_ID=

# Session ID for the decision loop.
# Default: slackoff_decision_loop
# OPENCLAW_SLACKOFF_DECISION_SESSION_ID=
